		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"isomorphic-dompurify": "^3.17.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	},
	"packageManager": "npm@11.17.0"
}
